{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Harzva/lark-relay/schemas/mobilecode-harvis-task.schema.json",
  "title": "MobileCode Harvis Task",
  "description": "Approval-gated task envelope for handing a Harvis Agent Room task to an existing MobileCode runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "correlation_id",
    "created_at",
    "source",
    "target",
    "handoff",
    "task",
    "evidence_contract"
  ],
  "properties": {
    "schema_version": {
      "const": "mobilecode.harvis.task.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^hm_task_[A-Za-z0-9._-]+$"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^corr_[A-Za-z0-9._-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "agent_room_topic_id", "requested_by"],
      "properties": {
        "system": {
          "const": "harvis"
        },
        "agent_room_topic_id": {
          "type": "string",
          "pattern": "^topic_[A-Za-z0-9._-]+$"
        },
        "agent_room_event_id": {
          "type": "string",
          "pattern": "^evt_[A-Za-z0-9._-]+$"
        },
        "requested_by": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "capabilities"],
      "properties": {
        "runtime": {
          "const": "mobilecode"
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "status_export",
              "evidence_export",
              "project_check",
              "validate",
              "android_emulator_smoke",
              "mobile_smoke_evidence",
              "github_pages_evidence",
              "github_actions_evidence"
            ]
          }
        },
        "device_selector": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "enum": ["none", "attached_device", "android_emulator", "ios_simulator"]
            },
            "label": {
              "type": "string"
            },
            "required": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "requires_approval", "allowed_actions", "risk"],
      "properties": {
        "mode": {
          "enum": ["read_only_status", "approval_gated_action"]
        },
        "requires_approval": {
          "type": "boolean"
        },
        "approval_id": {
          "type": "string",
          "pattern": "^appr_[A-Za-z0-9._-]+$"
        },
        "allowed_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["project_check", "validate"]
          }
        },
        "risk": {
          "enum": ["low", "medium", "high"]
        },
        "human_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "title", "input", "timeout_ms"],
      "properties": {
        "kind": {
          "enum": ["project_check", "validate"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["project_ref"],
          "properties": {
            "project_ref": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "value"],
              "properties": {
                "kind": {
                  "enum": ["repo", "workspace", "artifact"]
                },
                "value": {
                  "type": "string",
                  "minLength": 1
                },
                "commit": {
                  "type": "string",
                  "minLength": 7
                }
              }
            },
            "checks": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "instructions": {
              "type": "string"
            }
          }
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 3600000
        }
      }
    },
    "evidence_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_types", "redaction", "write_back"],
      "properties": {
        "expected_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "mobilecode.status.v1",
              "mobilecode.action_evidence.v1",
              "mobilecode.evidence.v1"
            ]
          }
        },
        "redaction": {
          "enum": ["public_safe", "private_local"]
        },
        "write_back": {
          "type": "object",
          "additionalProperties": false,
          "required": ["transport", "target"],
          "properties": {
            "transport": {
              "enum": ["lark-relay", "file", "harvis-http"]
            },
            "target": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
